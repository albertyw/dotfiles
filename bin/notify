#!/usr/bin/env bash
# This is a generic notification script that works across different platforms (Linux, WSL, macOS).
# It uses the appropriate notification system based on the detected environment.

set -euo pipefail
IFS=$'\n\t'

source ~/.ssh/other/ntfy.sh

MESSAGE="${1:-"notification"}"

curl \
  --header "Title: $MESSAGE" \
  --header "Priority: high" \
  --header "Tags: envelope_with_arrow" \
  --user "$NTFY_USERNAME:$NTFY_PASSWORD" \
  --data "$MESSAGE" \
  "$NTFY_ADDRESS/claude"
