{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "apiKeyHelper": "/Users/albertyw/.local/share/aifx/bin/claude-genai-token-helper",
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "false"
  },
  "fastMode": false,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "notify claude",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "otelHeadersHelper": "/Users/albertyw/.local/share/aifx/bin/claude-telemetry-token-helper",
  "permissions": {
    "allow": [
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gazelle *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(go doc *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mypy *)",
      "Bash(ollama ps*)",
      "Bash(printenv *)",
      "Bash(pwd)",
      "Bash(realpath *)",
      "Bash(ruff check *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(test *)",
      "Bash(tree *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "WebFetch",
      "mcp__monorepo-experts-mcp-server__generate_glue_go_mocks",
      "mcp__monorepo-experts-mcp-server__generate_standard_go_mocks",
      "mcp__monorepo-experts-mcp-server__get_coverage_report",
      "mcp__monorepo-experts-mcp-server__update_build_files"
    ],
    "defaultMode": "default",
    "deny": [
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  }
}
